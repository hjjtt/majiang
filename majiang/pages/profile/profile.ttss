.page { padding: 0; }
.profile-header { background: var(--green); padding: 60rpx 40rpx 48rpx; display: flex; align-items: center; gap: 28rpx; color: #fff; }
.profile-avatar { width: 112rpx; height: 112rpx; border-radius: 50%; background: rgba(255,255,255,.2); display: flex; align-items: center; justify-content: center; font-size: 48rpx; font-weight: 700; }
.profile-name { font-size: 36rpx; font-weight: 700; }
.profile-rank { font-size: 26rpx; opacity: .8; margin-top: 8rpx; }
.stat-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20rpx; padding: 32rpx; }
.stat-cell { background: var(--card-bg); border: 1rpx solid var(--border); border-radius: var(--radius); padding: 32rpx; text-align: center; }
.stat-value { font-size: 44rpx; font-weight: 700; color: var(--green); }
.stat-label { font-size: 24rpx; color: var(--text-dim); margin-top: 8rpx; }
